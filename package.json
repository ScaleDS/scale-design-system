{
  "name": "@scale/design-system",
  "version": "3.2.0-alpha.1",
  "description": "Scale Design System — A Lit-based agentic design system with machine-readable context for AI and human developers",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scss",
    "context",
    "assets",
    "mcp/dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scss/*": "./scss/*",
    "./scss/typography": "./dist/scss/typography.js",
    "./components/*.js": "./dist/components/*.js",
    "./components/*": "./dist/components/*.js",
    "./context/*": "./context/*",
    "./assets/*": "./assets/*",
    "./mcp": "./mcp/dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepare": "npm run build",
    "generate:context": "node scripts/generate-context.mjs",
    "prepublishOnly": "npm run build && npm run generate:context",
    "dev": "tsc --watch"
  },
  "keywords": [
    "design-system",
    "lit",
    "web-components",
    "agentic",
    "ai-ready",
    "machine-readable",
    "design-tokens"
  ],
  "author": "Christopher Deane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/scale-design-system"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "feather-icons": "^4.29.2",
    "lit": "^3.3.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/feather-icons": "^4.29.4",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
