{
  "name": "@scale-ds/scale-design-system",
  "version": "4.0.0-alpha.3",
  "description": "Scale Design System — A Lit-based agentic design system with machine-readable context for AI and human developers",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/**/*.js"
  ],
  "files": [
    "dist",
    "scss",
    "context",
    "assets",
    "mcp/dist",
    "vite-plugin.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./edit": {
      "types": "./dist/edit.d.ts",
      "import": "./dist/edit.js"
    },
    "./vite": "./vite-plugin.js",
    "./scss/*": "./scss/*",
    "./scss/typography": "./dist/scss/typography.js",
    "./components/*.js": "./dist/components/*.js",
    "./components/*": "./dist/components/*.js",
    "./context/*": "./context/*",
    "./assets/*": "./assets/*",
    "./mcp": "./mcp/dist/index.js"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepare": "npm run build",
    "generate:context": "node scripts/generate-context.mjs",
    "prepublishOnly": "npm run build && node scripts/generate-context.mjs --strict",
    "dev": "tsc --watch"
  },
  "keywords": [
    "design-system",
    "lit",
    "web-components",
    "agentic",
    "ai-ready",
    "machine-readable",
    "design-tokens"
  ],
  "author": "Christopher Deane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScaleDS/scale-design-system.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "feather-icons": "^4.29.2",
    "lit": "^3.3.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/feather-icons": "^4.29.4",
    "eslint": "^10.4.1",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
