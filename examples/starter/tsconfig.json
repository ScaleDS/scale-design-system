{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "noEmit": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"]
  },
  "include": ["src", "vite.config.ts"]
}
